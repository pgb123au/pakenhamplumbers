---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Thanks &mdash; we&rsquo;ll be in touch | Pakenham Plumbers"
  description="Your plumbing quote request has been received. We'll be in touch within 1 business day. Urgent? Call (03) 9003 0108."
  canonical="https://pakenhamplumbers.com.au/thanks/">
  <Fragment slot="head">
    <meta name="robots" content="noindex, follow">
  </Fragment>


  <section class="hero" style="padding: 4rem 0;">
    <div class="hero-inner">
      <span class="hero-eyebrow">Got it</span>
      <h1>Thanks &mdash; we&rsquo;ve got your details.</h1>
      <p class="hero-sub">
        We&rsquo;ll review your enquiry and get back to you within 1 business day. If your
        job is urgent &mdash; a burst pipe, gas leak, sewer overflow or no hot water &mdash;
        please call us on <a href="tel:+61390030108" style="color:#fbbf24; text-decoration:underline;">(03) 9003 0108</a>
        and we&rsquo;ll attend 24/7.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="tel:+61390030108">&#9742; Call now</a>
        <a class="btn btn-ghost" href="/">Back to home</a>
      </div>
    </div>
  </section>
</Layout>
