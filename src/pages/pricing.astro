    .cta-card-actions { display: flex; gap: 0.65rem; flex-wrap: wrap; }
    .btn-large { padding: 0.85rem 1.5rem; font-size: 1.05rem; }
    .faq-list { max-width: 60rem; margin: 1rem auto; }
    .faq-item { border-bottom: 1px solid #e5e7eb; padding: 0.85rem 0; }
    .faq-item[open] { background: rgba(0,0,0,0.02); }
    .faq-q { cursor: pointer; padding: 0.4rem 0.5rem; font-size: 1.05rem; }
