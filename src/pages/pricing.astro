    .numbered-list, .bullet-list { max-width: 65rem; margin: 1rem 0; padding-left: 1.5rem; line-height: 1.7; }
    .numbered-list li, .bullet-list li { margin: 0.65rem 0; }
    .cta-card-section { padding: 2rem 1rem; }
    .cta-card {
      max-width: 56rem; margin: 0 auto;
      background: #fff; border: 1px solid #e5e7eb; border-radius: 10px;
